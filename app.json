{
  "expo": {
    "name": "Finotify",
    "slug": "Finotify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ic.png",
    "scheme": "finotify",
    "newArchEnabled": true,
    "backgroundColor": "#0A63BC",

    "splash": {
      "image": "./assets/ic.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A63BC"
    },

    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#0A63BC"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ic.png",
        "backgroundColor": "#0A63BC"
      },
      "backgroundColor": "#0A63BC",
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.myapp"
    },

    "web": {
      "favicon": "./assets/ic.png"
    },

    "plugins": [
      "expo-router",
      "expo-font"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "d35d5278-aea8-4470-8ffc-04b79031526a"
      }
    }
  }
}